# ============================================================
# VoiceX5 - Configuration
# Copier ce fichier vers .env et remplir les valeurs
# ============================================================

# === API KEYS (REQUIS) ===
ANTHROPIC_API_KEY=sk-ant-api03-VOTRE_CLE_ICI

# === TWILIO (Optionnel - pour téléphonie réelle) ===
TWILIO_ACCOUNT_SID=ACXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_PHONE_NUMBER=+15551234567

# === NEO4J (SafetyGraph) ===
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=voicex5secure123

# === VECTOR DATABASE ===
QDRANT_URL=http://qdrant:6333
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-mpnet-base-v2

# === AUDIO PROCESSING ===
STT_MODEL=large-v3
STT_LANGUAGE=fr
STT_DEVICE=cuda
TTS_ENDPOINT=http://orpheus:8080
TTS_VOICE=french_female

# === SAMPLE RATES ===
INPUT_SAMPLE_RATE=16000
OUTPUT_SAMPLE_RATE=24000

# === SERVER ===
HOST=0.0.0.0
PORT=8000
BASE_URL=https://votre-domaine.com
STREAM_URL=wss://votre-domaine.com/ws/twilio

# === OBSERVABILITY ===
OPIK_API_KEY=
GRAFANA_PASSWORD=admin
LOG_LEVEL=INFO

# === REDIS (Sessions) ===
REDIS_URL=redis://redis:6379/0

# === NOTIFICATIONS ===
SLACK_WEBHOOK_URL=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
NOTIFICATION_EMAIL_FROM=voicex5@company.com

# === SÉCURITÉ ===
SECRET_KEY=your-secret-key-change-in-production
ALLOWED_ORIGINS=http://localhost:3000,https://votre-domaine.com

# === FEATURE FLAGS ===
ENABLE_TWILIO=false
ENABLE_OUTBOUND_CALLS=false
ENABLE_SMS_NOTIFICATIONS=true
ENABLE_EMAIL_NOTIFICATIONS=true
ENABLE_SLACK_NOTIFICATIONS=false

# === LIMITES ===
MAX_CALL_DURATION_SECONDS=600
MAX_CONCURRENT_CALLS=10
SILENCE_TIMEOUT_MS=500
